namespace Livt.Timing

/**
 * Produces a one-context-tick pulse every second.
 */
component PeriodicTickProvider1s
{
    provider: PeriodicTickProvider

    /**
     * Creates a provider whose period is derived from this component's context.
     */
    new(tick: out logic)
    {
        this.provider = new PeriodicTickProvider(this.context.TicksFor(1s), tick)
    }

    /**
     * Returns the one-second interval in ticks of this component's context.
     */
    public fn GetPeriodTicks() uint
    {
        return this.provider.GetPeriodTicks()
    }
}
